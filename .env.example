# Variáveis de ambiente do MestreApp
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.

# Google OAuth 2.0 Client ID (obtenha em https://console.cloud.google.com)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# URL do backend para desenvolvimento local
BACKEND_URL_DEV=http://localhost:3333

# URL do backend para produção
BACKEND_URL_PROD=https://mestre-app-backend.vercel.app
